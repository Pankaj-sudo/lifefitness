rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── payment proofs ────────────────────────────────────────
    // Any authenticated user can upload; only the order owner or an admin can read.
    // We can't join Firestore from Storage rules, so ownership of the orderId folder
    // is enforced in the Cloud Function (createOrder validates auth before writing).
    match /payment_proofs/{orderId}/{filename} {
      allow write: if request.auth != null
                   && request.resource.size  < 5 * 1024 * 1024
                   && request.resource.contentType.matches('image/.*');

      // Admin can always read; the downloading user needs the signed URL from Firestore
      // (returned by getDownloadURL after upload), which is effectively owner-gated.
      allow read: if request.auth != null && request.auth.token.admin == true;
    }

    // Deny everything else by default
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
